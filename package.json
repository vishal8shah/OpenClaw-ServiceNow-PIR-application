{
  "name": "openclaw_servicenow_starter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#now:*": "./@types/servicenow/fluent/*/index.js"
  },
  "scripts": {
    "build": "now-sdk build",
    "deploy": "now-sdk install",
    "transform": "now-sdk transform",
    "types": "now-sdk dependencies",
    "codex:plan": "tsx src/codex_runner.ts plan templates/requirement.md",
    "codex:implement": "tsx src/codex_runner.ts implement templates/requirement.md",
    "codex:review": "tsx src/codex_runner.ts review .",
    "sn:init": "bash scripts/create_scoped_app.sh",
    "sn:build": "npx @servicenow/sdk build",
    "sn:install": "bash scripts/install_app.sh"
  },
  "dependencies": {
    "@openai/codex-sdk": "latest",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@servicenow/sdk": "4.5.0",
    "@servicenow/glide": "27.0.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
